# Example environment configuration
# Copy to .env and adjust values

# Required
ANKICONNECT_COLLECTION_PATH=/path/to/your/collection.anki2

# Optional - Server settings
ANKICONNECT_PORT=8765
ANKICONNECT_BIND=127.0.0.1

# Optional - AnkiWeb sync (required for sync action)
# ANKICONNECT_ANKIWEB_USER=your@email.com
# ANKICONNECT_ANKIWEB_PASS=your_password

# Optional - Custom sync server (default: AnkiWeb)
# ANKICONNECT_ANKIWEB_URL=https://sync.ankiweb.net

# Optional - OpenAI Secure MCP Tunnel (both required by the tunnel command)
# CONTROL_PLANE_TUNNEL_ID=tunnel_0123456789abcdef0123456789abcdef
# CONTROL_PLANE_API_KEY=your_runtime_api_key

# Optional - Override tunnel-client discovery when it is not on PATH
# TUNNEL_CLIENT_PATH=/path/to/tunnel-client
